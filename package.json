{
  "name": "@snarkipus/opencode-beads",
  "version": "0.7.0",
  "type": "module",
  "description": "A plugin for OpenCode that provides integration with the beads issue tracker.",
  "author": "Matt Jackson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snarkipus/opencode-beads.git"
  },
  "homepage": "https://github.com/snarkipus/opencode-beads#readme",
  "bugs": {
    "url": "https://github.com/snarkipus/opencode-beads/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "opencode",
    "plugin",
    "beads",
    "agent",
    "ai"
  ],
  "main": "./src/plugin.ts",
  "types": "./src/plugin.ts",
  "exports": {
    ".": {
      "types": "./src/plugin.ts",
      "import": "./src/plugin.ts"
    }
  },
  "files": [
    "src",
    "vendor",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "opencode-beads": "src/init-cli.ts"
  },
  "scripts": {
    "test": "bun test",
    "test:package": "bun scripts/test-package.ts",
    "test:provenance": "bun test tests/provenance.test.ts",
    "test:release": "bun test tests/release.test.ts",
    "test:vendor": "bun scripts/validate-vendor.ts vendor",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.18.3 <2",
    "@opencode-ai/sdk": ">=1.18.3 <2"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": true
    },
    "@opencode-ai/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.18.4",
    "@opencode-ai/sdk": "1.18.4",
    "@types/bun": "1.3.4",
    "@types/node": "^22.0.0",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  }
}
